generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id              String    @id @default(uuid())
  applicationCode String    @unique
  firstName       String
  lastName        String
  email           String
  phone           String
  loanAmount      Decimal
  loanTermMonths  Int       @default(6)
  platform        String?
  ssnEncrypted    String?
  ssnHash         String?
  plaidAccessToken String?
  plaidAccountId  String?
  plaidItemId     String?
  plaidUserToken  String?
  // Token returned by /asset_report/create. Plaid uses it as the key
  // to /asset_report/get. Stored so the webhook handler can fetch the
  // report when ASSETS:PRODUCT_READY fires.
  plaidAssetReportToken String?
  plaidLinkStale  Boolean   @default(false)
  monthlyIncome   Decimal?
  totalIncome     Decimal?
  riskScore       Decimal?
  bankBalance     Decimal?
  riskModelId     String?
  // AI-driven risk analysis (Gemini). Reads from Plaid Assets + parsed
  // bank statements + applicant context and returns a score, recommended
  // weekly rate, verdict, green/red flags, and key factors. Populated
  // by runAiRiskAnalysis() — see src/lib/risk/ai-risk.ts. The full
  // structured JSON lives in aiRiskAnalysisJson; the headline fields
  // are duplicated for easy querying/sorting.
  aiRiskScore         Float?
  aiRecommendedRate   Float?
  aiRiskVerdict       String?  // "APPROVE" | "MANUAL_REVIEW" | "REJECT"
  aiRiskAnalysisJson  String?
  aiRiskAnalysisAt    DateTime?
  interestRate    Decimal?
  approvedBy      String?
  approvedAt      DateTime?
  fundedAt        DateTime?
  fundedAmount    Decimal?
  rejectionReason String?
  status          String    @default("PENDING")
  increaseTransferId       String?
  increaseTransferStatus   String?
  increaseDisburseError    String?
  identityNeedsReview      Boolean   @default(false)
  plaidIdentityName        String?
  offerStatus              String    @default("PENDING")
  offeredMinAmount         Decimal?
  offeredMaxAmount         Decimal?
  offeredTermsJson         String?
  offerToken               String?   @unique
  offerSentAt              DateTime?
  acceptedAmount           Decimal?
  acceptedTermIndex        Int?
  acceptedAt               DateTime?
  workerType               String?
  workStartMonth           Int?
  workStartYear            Int?
  addressStreet            String?
  addressCity              String?
  addressState             String?
  addressZip               String?
  dateOfBirth              String?
  bankName                 String?
  bankRoutingNumberManual  String?
  bankAccountNumberManual  String?
  bankInfoMismatch         Boolean   @default(false)
  refinedMonthlyIncome     Decimal?
  classifications          TransactionClassification[]
  plaidIdentityAddress     String?
  plaidIdentityEmail       String?
  plaidIdentityPhone       String?
  plaidInstitutionName     String?
  plaidAccountName         String?
  plaidAccountMask         String?
  plaidAccountSubtype      String?
  availableBalance         Decimal?
  avgWeeklyIncome          Decimal?
  depositCount90d          Int?
  largestDeposit           Decimal?
  depositCadence           String?
  // Day-of-week (0=Sunday … 6=Saturday) computed from the borrower's
  // bank deposits — typically the day after the largest recurring
  // income lands, when balance is freshest. Used by the offer accept
  // flow to snap each weekly payment due date so ACH debits land when
  // money is most likely to be there.
  preferredChargeDay       Int?
  lastPlaidRefresh         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  documents       Document[]
  payments        Payment[]
  collectionEvents CollectionEvent[]
  contact         Contact?

  @@index([status])
  @@index([email])
  @@index([ssnHash])
  @@index([plaidItemId])
}

model TransactionClassification {
  id               String   @id @default(uuid())
  applicationId    String
  counterpartyName String
  classification   String
  txCount          Int
  totalAmount      Decimal
  isInflow         Boolean  @default(true)
  sampleTxId       String
  sampleTxDate     DateTime
  sampleTxAmount   Decimal
  classifiedAt     DateTime @default(now())
  application      Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, counterpartyName])
  @@index([applicationId])
}

model Document {
  id            String   @id @default(uuid())
  applicationId String
  fileName      String
  mimeType      String
  fileSize      Int
  storagePath   String
  documentType  String   @default("PAY_STUB")
  createdAt     DateTime @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model LoanRule {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("ADMIN")
  createdAt    DateTime  @default(now())
  contacts     Contact[]
}

model Payment {
  id              String    @id @default(uuid())
  applicationId   String
  amount          Decimal
  principal       Decimal
  interest        Decimal
  lateFee         Decimal   @default(0)
  dueDate         DateTime
  paidAt          DateTime?
  status          String    @default("PENDING")
  paymentNumber   Int
  achTransferId   String?
  increaseTransferId     String?
  increaseTransferStatus String?
  increaseLastError      String?
  retryCount      Int       @default(0)
  lastRetryAt     DateTime?
  createdAt       DateTime  @default(now())
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([status])
  @@index([dueDate])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String
  performedBy String
  details     String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([createdAt])
}

model RiskProfile {
  id               String    @id @default(uuid())
  applicationId    String
  ssnHash          String
  platform         String
  monthlyIncome    Decimal
  loanAmount       Decimal
  loanTermMonths   Int
  interestRate     Decimal
  outcome          String
  totalPaid        Decimal
  totalOwed        Decimal
  latePaymentCount Int       @default(0)
  defaultedAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@index([platform])
  @@index([outcome])
  @@index([ssnHash])
}

model CollectionEvent {
  id            String   @id @default(uuid())
  applicationId String
  eventType     String
  performedBy   String?
  notes         String?
  createdAt     DateTime @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model RiskModel {
  id           String   @id @default(uuid())
  version      Int
  coefficients String
  intercept    Float
  features     String
  trainingSize Int
  accuracy     Float
  precision    Float
  recall       Float
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ─── Content Management ─────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  articles    Article[]

  @@index([slug])
}

model Tag {
  id        String       @id @default(uuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())
  articles  ArticleTag[]

  @@index([slug])
}

model ArticleTag {
  id        String  @id @default(uuid())
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

model Article {
  id              String       @id @default(uuid())
  title           String
  slug            String       @unique
  body            String
  excerpt         String?
  featuredImage   String?
  categoryId      String?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonicalUrl    String?
  noIndex         Boolean      @default(false)
  published       Boolean      @default(false)
  publishedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  category        Category?    @relation(fields: [categoryId], references: [id])
  tags            ArticleTag[]

  @@index([slug])
  @@index([published])
  @@index([categoryId])
}

model PlatformPage {
  id                  String    @id @default(uuid())
  platformName        String    @unique
  slug                String    @unique
  heroHeadline        String
  heroSubtext         String
  platformDescription String
  avgEarnings         String?
  topEarnerRange      String?
  loanDetailsHtml     String?
  faqEntries          String    @default("[]")
  ctaText             String?
  ctaSubtext          String?
  metaTitle           String?
  metaDescription     String?
  ogImage             String?
  canonicalUrl        String?
  noIndex             Boolean   @default(false)
  published           Boolean   @default(false)
  publishedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([slug])
  @@index([published])
}

model StatePage {
  id                 String    @id @default(uuid())
  stateName          String    @unique
  stateCode          String    @unique
  slug               String    @unique
  heroHeadline       String
  heroSubtext        String
  regulationsSummary String?
  loanAvailability   String?
  localStats         String    @default("[]")
  faqEntries         String    @default("[]")
  ctaText            String?
  metaTitle          String?
  metaDescription    String?
  ogImage            String?
  canonicalUrl       String?
  noIndex            Boolean   @default(false)
  published          Boolean   @default(false)
  publishedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([slug])
  @@index([published])
}

model ToolPage {
  id                  String    @id @default(uuid())
  title               String
  slug                String    @unique
  description         String
  toolComponent       String
  body                String?
  relatedArticleSlugs String    @default("[]")
  metaTitle           String?
  metaDescription     String?
  ogImage             String?
  canonicalUrl        String?
  noIndex             Boolean   @default(false)
  published           Boolean   @default(false)
  publishedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([slug])
  @@index([published])
}

model ComparisonPage {
  id              String    @id @default(uuid())
  title           String
  slug            String    @unique
  entityA         String
  entityB         String
  introHtml       String?
  comparisonGrid  String    @default("[]")
  verdict         String?
  faqEntries      String    @default("[]")
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonicalUrl    String?
  noIndex         Boolean   @default(false)
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([published])
}

model ContentImage {
  id          String   @id @default(uuid())
  fileName    String
  mimeType    String
  fileSize    Int
  storagePath String
  altText     String?
  createdAt   DateTime @default(now())
}

model LandingPage {
  id                String    @id @default(uuid())
  slug              String    @unique
  // SEO
  metaTitle         String
  metaDescription   String
  // Header
  phoneNumber       String?
  // Hero
  heroBadge         String
  heroHeadlineLine1 String
  heroHeadlineLine2 String?
  heroHeadlineLine3 String?
  heroSubtext       String
  heroIllustration  String?
  // Trust
  trustItems        String    @default("[]")
  trustStats        String    @default("[]")
  // How it works
  howItWorksTitle   String    @default("Three steps. No paperwork.")
  howItWorksSubtext String?
  howItWorksSteps   String    @default("[]")
  // Testimonials
  testimonialsTitle String    @default("Drivers we've funded.")
  testimonials      String    @default("[]")
  // FAQ
  faqTitle          String    @default("Common questions.")
  faqs              String    @default("[]")
  // Final CTA
  finalCtaHeadline  String    @default("Ready to get funded?")
  finalCtaSubtext   String?
  finalCtaButtonText String   @default("Apply Now")
  // Form config
  formTemplateSlug  String?
  utmSource         String    @default("lp")
  utmCampaign       String
  formPlatforms     String    @default("[]")
  defaultAmount     Int       @default(3000)
  defaultTermWeeks  Int       @default(4)
  // Meta
  published         Boolean   @default(false)
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([slug])
  @@index([published])
}

// ─── CRM ─────────────────────────────────────────────────────

model Contact {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String?
  email           String    @unique
  phone           String?
  stage           String    @default("LEAD")
  assignedRepId   String?
  assignedRep     AdminUser? @relation(fields: [assignedRepId], references: [id])
  source          String?
  pennyClickId    String?
  smsOptIn        Boolean   @default(true)
  smsOptOutAt     DateTime?
  phoneVerifiedAt DateTime?
  utmSource       String?
  utmCampaign     String?
  utmMedium       String?
  utmTerm         String?
  utmContent      String?
  gclid           String?
  gbraid          String?
  wbraid          String?
  fbclid          String?
  ttclid          String?
  msclkid         String?
  landingPage     String?
  referrer        String?
  userAgent       String?
  ipAddress       String?
  applicationId   String?   @unique
  application     Application? @relation(fields: [applicationId], references: [id])
  lastAppStep     Int?
  loanAmountIntent Decimal?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tags                ContactTag[]
  activities          Activity[]
  emailEvents         EmailEvent[]
  sequenceEnrollments SequenceEnrollment[]
  agentSessions       AgentSession[]
  verifications       AgentVerification[]
  tickets             SupportTicket[]

  @@index([stage])
  @@index([assignedRepId])
  // Admin-archived contacts are hidden from the default contacts list
  // (and from CRM stats) but kept in the DB so we don't lose history.
  // Null = active. Set = archived at this timestamp.
  archivedAt   DateTime?

  @@index([email])
  @@index([createdAt])
  @@index([pennyClickId])
  @@index([archivedAt])
}

model ContactTag {
  id        String  @id @default(uuid())
  contactId String
  tag       String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, tag])
  @@index([contactId])
  @@index([tag])
}

model Activity {
  id          String   @id @default(uuid())
  contactId   String
  type        String
  title       String
  details     String?
  performedBy String?
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([contactId])
  @@index([type])
  @@index([createdAt])
}

model FormTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  steps       String   @default("[]")
  isDefault   Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// ─── Email Marketing ─────────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  subject   String
  body      String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailCampaign {
  id            String    @id @default(uuid())
  name          String
  subject       String
  body          String
  templateId    String?
  segmentRules  String    @default("[]")
  audienceCount Int       @default(0)
  status        String    @default("DRAFT")
  scheduledAt   DateTime?
  sentAt        DateTime?
  totalSent     Int       @default(0)
  totalOpened   Int       @default(0)
  totalClicked  Int       @default(0)
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

model EmailSequence {
  id           String   @id @default(uuid())
  name         String
  description  String?
  steps        String   @default("[]")
  triggerType  String
  triggerValue String?
  active       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SequenceEnrollment {
  id          String    @id @default(uuid())
  contactId   String
  sequenceId  String
  currentStep Int       @default(0)
  status      String    @default("ACTIVE")
  nextSendAt  DateTime?
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  enrolledAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([contactId, sequenceId])
  @@index([status])
  @@index([nextSendAt])
}

model EmailEvent {
  id         String   @id @default(uuid())
  contactId  String
  campaignId String?
  sequenceId String?
  type       String
  subject    String?
  messageId  String?
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([contactId])
  @@index([campaignId])
  @@index([type])
}

/// Notification center configuration. One singleton row. Each field is a
/// comma-separated list of emails that receive the notification for that
/// event. Empty string disables the notification entirely.
model NotificationConfig {
  id                          String   @id @default("singleton")
  // Fired when the chat widget creates a brand-new session (lead provides
  // their name + email before the first message).
  chatStartedEmails           String   @default("")
  // Fired when a public funnel applicant submits the application.
  applicationSubmittedEmails  String   @default("")
  // Fired when a brand-new Contact is created (lead capture from any
  // source: funnel, chat, landing page form, etc.)
  leadCreatedEmails           String   @default("")
  // Fired when an inbound email lands at info@pennylime.com and matches
  // a known Contact. POSTed by the email provider's inbound webhook.
  inboundEmailEmails          String   @default("")
  updatedAt                   DateTime @updatedAt
}

model TrackingConfig {
  id                            String   @id @default("singleton")
  // Google Ads
  googleAdsConversionId         String?
  googleAdsDeveloperToken       String?
  googleAdsCustomerId           String?
  googleAdsLoginCustomerId      String?
  googleAdsRefreshToken         String?
  googleAdsClientId             String?
  googleAdsClientSecret         String?
  // GA4
  ga4MeasurementId              String?
  ga4ApiSecret                  String?
  // Meta
  metaPixelId                   String?
  metaConversionsApiToken       String?
  metaTestEventCode             String?
  metaAdAccountId               String?
  // TikTok
  tiktokPixelId                 String?
  tiktokAccessToken             String?
  tiktokTestEventCode           String?
  // Microsoft Ads (Bing)
  microsoftUetTagId             String?
  microsoftConversionsApiToken  String?
  // Per-event conversion mappings (JSON: { event_name: { google_ads_label, meta_event, tiktok_event, microsoft_goal } })
  eventMappings                 String   @default("{}")
  // Raw script injection
  customHeadHtml                String?
  customBodyHtml                String?
  // Twilio SMS
  twilioAccountSid              String?
  twilioAuthToken               String?
  twilioFromNumber              String?
  twilioMessagingServiceSid     String?
  twilioVerifyServiceSid        String?
  // Toggles
  enabled                       Boolean  @default(true)
  testMode                      Boolean  @default(false)
  updatedAt                     DateTime @updatedAt
}

model TrackingEvent {
  id            String   @id @default(uuid())
  eventName     String
  contactId     String?
  applicationId String?
  pennyClickId  String?
  clickIds      String   @default("{}")
  payload       String   @default("{}")
  platforms     String   @default("{}")
  value         Decimal?
  currency      String?  @default("USD")
  status        String   @default("pending")
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([eventName])
  @@index([contactId])
  @@index([pennyClickId])
  @@index([status])
  @@index([createdAt])
}

model PennyClick {
  id               String   @id
  contactId        String?
  visitCount       Int      @default(1)
  // first-touch attribution
  firstUtmSource   String?
  firstUtmMedium   String?
  firstUtmCampaign String?
  firstUtmTerm     String?
  firstUtmContent  String?
  firstGclid       String?
  firstGbraid      String?
  firstWbraid      String?
  firstFbclid      String?
  firstTtclid      String?
  firstMsclkid     String?
  firstLandingPage String?
  firstReferrer    String?
  firstUserAgent   String?
  firstIpAddress   String?
  // last-touch attribution
  lastUtmSource    String?
  lastUtmMedium    String?
  lastUtmCampaign  String?
  lastGclid        String?
  lastFbclid       String?
  lastTtclid       String?
  lastMsclkid      String?
  lastLandingPage  String?
  firstSeen        DateTime @default(now())
  lastSeen         DateTime @default(now())

  @@index([contactId])
  @@index([firstSeen])
}

model AdSpend {
  id          String   @id @default(uuid())
  date        DateTime
  platform    String
  campaign    String?
  spend       Decimal
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  currency    String   @default("USD")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([platform])
}

model SmsTemplate {
  id          String   @id @default(uuid())
  name        String
  body        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SmsMessage {
  id              String   @id @default(uuid())
  contactId       String?
  toNumber        String
  fromNumber      String
  body            String
  templateId      String?
  campaignId      String?
  twilioSid       String?  @unique
  status          String   @default("queued") // queued, sent, delivered, failed, undelivered
  errorMessage    String?
  errorCode       String?
  segments        Int      @default(1)
  priceUsd        Decimal?
  sentAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contactId])
  @@index([status])
  @@index([twilioSid])
  @@index([createdAt])
}

model SmsCampaign {
  id              String    @id @default(uuid())
  name            String
  body            String
  templateId      String?
  segmentRules    String    @default("[]")
  audienceCount   Int       @default(0)
  status          String    @default("DRAFT")
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalSent       Int       @default(0)
  totalDelivered  Int       @default(0)
  totalFailed     Int       @default(0)
  totalReplied    Int       @default(0)
  totalOptOut     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
}

model SmsSequence {
  id           String   @id @default(uuid())
  name         String
  description  String?
  steps        String   @default("[]")
  triggerType  String
  triggerValue String?
  active       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SmsSequenceEnrollment {
  id          String    @id @default(uuid())
  contactId   String
  sequenceId  String
  currentStep Int       @default(0)
  status      String    @default("ACTIVE")
  nextSendAt  DateTime?
  enrolledAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([contactId, sequenceId])
  @@index([status])
  @@index([nextSendAt])
}

/// Immutable record of a customer's ACH authorization at offer
/// acceptance. Captures the exact text shown, the schedule they
/// agreed to, IP/user-agent, and the agreement version hash so we
/// can prove later what was on screen when they clicked.
model AchAuthorization {
  id                  String   @id @default(uuid())
  applicationId       String
  contactId           String?
  acceptedAt          DateTime @default(now())
  ipAddress           String?
  userAgent           String?
  bankAccountMask     String?  // last 4 of debited account
  bankName            String?
  scheduleJson        String   // JSON: [{ date, amount, principal, interest }]
  totalDebitAmount    Decimal
  authorizationText   String   // exact text shown on screen
  agreementHash       String?  // SHA-256 of the agreement template version
  agreementVersion    String?  @default("v1-2026-05-17")
  // Stronger consent evidence — captured alongside the inline
  // agreement viewer and typed-name signature on the offer page.
  signedName          String?  // full legal name the borrower typed at acceptance
  scrolledToBottom    Boolean  @default(false) // confirmed they read to end

  @@index([applicationId])
  @@index([contactId])
}

model PhoneVerification {
  id          String    @id @default(uuid())
  phone       String
  codeHash    String
  attempts    Int       @default(0)
  verifiedAt  DateTime?
  expiresAt   DateTime
  ipAddress   String?
  contactId   String?
  createdAt   DateTime  @default(now())

  @@index([phone])
  @@index([createdAt])
}

// ============================================================================
// Social Bot
// ============================================================================

model SocialAccount {
  id                String          @id @default(uuid())
  platform          String          // "instagram" | "facebook" | "linkedin" | "tiktok"
  handle            String          // "@pennylime"
  accessToken       String          // encrypted at rest (AES-GCM via NEXTAUTH_SECRET)
  refreshToken      String?
  tokenExpiresAt    DateTime?
  platformAccountId String?         // IG business user id / FB page id / LI org id (TT not used)
  botCookies        String?         // encrypted instagrapi/cookie session blob
  botStatus         String          @default("healthy") // "healthy" | "challenged" | "banned"
  lastBotAction     DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  posts             SocialPost[]
  engagements       EngagementLog[]

  @@unique([platform, handle])
}

model SocialPost {
  id             String        @id @default(uuid())
  accountId      String
  account        SocialAccount @relation(fields: [accountId], references: [id])
  topic          String
  body           String        @db.Text
  imageUrl       String?
  scheduledFor   DateTime
  status         String        @default("pending") // "pending"|"published"|"failed"|"blocked"
  platformPostId String?
  publishError   String?       @db.Text
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())

  @@index([status, scheduledFor])
}

model TopicPool {
  id         String    @id @default(uuid())
  topic      String    @db.Text
  category   String    // "tax" | "cashflow" | "platform-tips" | "earnings" | "savings" | "news"
  lastUsedAt DateTime?
  useCount   Int       @default(0)
  active     Boolean   @default(true)
}

model EngagementTarget {
  id           String    @id @default(uuid())
  platform     String
  source       String    // "hashtag:#uberdriver" | "geo:los-angeles+keyword:doordash"
  targetHandle String
  targetPostId String?
  action       String    // "like" | "follow"
  status       String    @default("queued") // "queued"|"done"|"skipped"|"failed"
  createdAt    DateTime  @default(now())
  processedAt  DateTime?

  @@index([platform, status, createdAt])
}

model EngagementLog {
  id           String        @id @default(uuid())
  accountId    String
  account      SocialAccount @relation(fields: [accountId], references: [id])
  platform     String
  action       String        // "like" | "follow" | "unfollow"
  targetHandle String
  targetPostId String?
  success      Boolean
  error        String?       @db.Text
  createdAt    DateTime      @default(now())

  @@index([accountId, createdAt])
}

// ─── AI Support Agent ────────────────────────────────────────

model AgentSession {
  id             String   @id @default(uuid())
  channel        String   // "chat" | "sms" | "voice"
  contactId      String?
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  authLevel      String   @default("anon")
  // "ai" (Gemini answers automatically) or "human" (admin took over;
  // user messages don't trigger an AI turn and wait for an admin reply).
  mode           String   @default("ai")
  // Lead-capture fields collected by the chat widget before the user can
  // send a message. Duplicate of contact.firstName / contact.email by
  // design so we don't lose the lead if the contact upsert fails or the
  // visitor never makes it past the form.
  leadFirstName  String?
  leadLastName   String?
  leadEmail      String?
  // Tracks when the user's chat widget last polled for new messages. We
  // use it as a proxy for "user is online right now" — if it's > 30s
  // stale and admin sends a message, the message is also emailed.
  lastPolledAt   DateTime?
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  endReason      String?
  costCents      Int      @default(0)
  metadata       Json?
  // Admin-archived sessions hide from the default sessions list and
  // from the unread-count badge. Null = active.
  archivedAt     DateTime?
  messages       AgentMessage[]
  toolCalls      AgentToolCall[]
  tickets        SupportTicket[]
  @@index([contactId])
  @@index([channel, startedAt])
  @@index([mode, startedAt])
  @@index([archivedAt])
}

model AgentMessage {
  id           String   @id @default(uuid())
  sessionId    String
  session      AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         String   // "user" | "assistant" | "system" | "tool"
  // Set to the admin's email when role="assistant" and the message was
  // typed by a human during takeover. Null when the AI generated it.
  senderEmail  String?
  // True when this message was emailed to the user because they were
  // offline at the time (lastPolledAt was stale). Prevents double-email.
  emailedAt    DateTime?
  text         String
  tokensIn     Int?
  tokensOut    Int?
  createdAt    DateTime @default(now())
  @@index([sessionId, createdAt])
}

model AgentToolCall {
  id            String   @id @default(uuid())
  sessionId     String
  session       AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name          String
  argsRedacted  Json
  resultStatus  String   // "ok" | "denied_auth" | "denied_confirm" | "error" | "rate_limited"
  resultSummary String?
  errorMessage  String?
  durationMs    Int
  createdAt     DateTime @default(now())
  @@index([sessionId, createdAt])
  @@index([name, resultStatus, createdAt])
}

model AgentVerification {
  id           String   @id @default(uuid())
  contactId    String
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel      String
  attempts     Int      @default(0)
  lockedUntil  DateTime?
  lastTriedAt  DateTime @default(now())
  @@unique([contactId, channel])
}

model SupportTicket {
  id              String   @id @default(uuid())
  sessionId       String?
  session         AgentSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  contactId       String?
  // Tickets intentionally survive contact deletion (audit trail). transcript
  // is snapshotted here so deleting the source session still leaves a record.
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  reason          String
  transcript      String
  status          String   @default("open")
  assignedTo      String?
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?
  @@index([status, createdAt])
}

model AgentError {
  id          String   @id @default(uuid())
  sessionId   String?
  toolName    String?
  message     String
  stack       String?
  createdAt   DateTime @default(now())
  @@index([createdAt])
}
