generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id              String    @id @default(uuid())
  applicationCode String    @unique
  firstName       String
  lastName        String
  email           String
  phone           String
  loanAmount      Decimal
  loanTermMonths  Int       @default(6)
  // Repayment cadence the borrower chose in the funnel. "WEEKLY"
  // (default) debits once a week; "DAILY" debits every business day
  // (Mon-Fri) for the same total. Read at offer acceptance to build
  // the Payment schedule.
  paymentFrequency String   @default("WEEKLY")
  platform        String?
  ssnEncrypted    String?
  ssnHash         String?
  plaidAccessToken String?
  plaidAccountId  String?
  plaidItemId     String?
  plaidUserToken  String?
  // Token returned by /asset_report/create. Plaid uses it as the key
  // to /asset_report/get. Stored so the webhook handler can fetch the
  // report when ASSETS:PRODUCT_READY fires.
  plaidAssetReportToken String?
  plaidLinkStale  Boolean   @default(false)
  monthlyIncome   Decimal?
  totalIncome     Decimal?
  riskScore       Decimal?
  bankBalance     Decimal?
  riskModelId     String?
  // AI-driven risk analysis (Gemini). Reads from Plaid Assets + parsed
  // bank statements + applicant context and returns a score, recommended
  // weekly rate, verdict, green/red flags, and key factors. Populated
  // by runAiRiskAnalysis() — see src/lib/risk/ai-risk.ts. The full
  // structured JSON lives in aiRiskAnalysisJson; the headline fields
  // are duplicated for easy querying/sorting.
  aiRiskScore         Float?
  aiRecommendedRate   Float?
  aiRiskVerdict       String?  // "APPROVE" | "MANUAL_REVIEW" | "REJECT"
  aiRiskAnalysisJson  String?
  aiRiskAnalysisAt    DateTime?
  interestRate    Decimal?
  approvedBy      String?
  approvedAt      DateTime?
  fundedAt        DateTime?
  fundedAmount    Decimal?
  rejectionReason String?
  status          String    @default("PENDING")
  increaseTransferId       String?
  increaseTransferStatus   String?
  increaseDisburseError    String?
  // Times the borrower used the "skip one payment" feature in /portal.
  // Each skip charges a 5%-of-advance fee + shifts the next pending
  // payment to the end of the schedule. Capped to 1 per advance for now.
  skipsUsed                Int       @default(0)
  identityNeedsReview      Boolean   @default(false)
  plaidIdentityName        String?
  offerStatus              String    @default("PENDING")
  offeredMinAmount         Decimal?
  offeredMaxAmount         Decimal?
  offeredTermsJson         String?
  offerToken               String?   @unique
  offerSentAt              DateTime?
  acceptedAmount           Decimal?
  acceptedTermIndex        Int?
  acceptedAt               DateTime?
  workerType               String?
  // For BUSINESS_OWNER applicants: the industry / category they
  // operate in (Restaurant, Retail, Trades, Services, eCommerce, etc.).
  // When the applicant picks "Other", the free-text description they
  // type is appended after a colon (e.g. "Other: Tarot reading studio").
  businessType             String?
  // Employer Identification Number, collected from BUSINESS_OWNER
  // applicants on the Documents step (format "XX-XXXXXXX"). Used as
  // business-existence proof alongside the uploaded 90-day statement.
  ein                      String?
  // Result of verifyWorkSignals(): does the bank data actually show the
  // gig/business income the applicant declared? "VERIFIED" | "WEAK" |
  // "UNVERIFIED". workVerificationJson holds the matched counterparties,
  // totals, and the human-readable reason. workNeedsReview soft-flags
  // weak/unverified applicants for a human without blocking submission.
  workVerificationStatus   String?
  workVerificationJson     String?
  workVerificationAt       DateTime?
  workNeedsReview          Boolean   @default(false)
  workStartMonth           Int?
  workStartYear            Int?
  addressStreet            String?
  addressCity              String?
  addressState             String?
  addressZip               String?
  dateOfBirth              String?
  bankName                 String?
  bankRoutingNumberManual  String?
  bankAccountNumberManual  String?
  bankInfoMismatch         Boolean   @default(false)
  refinedMonthlyIncome     Decimal?
  classifications          TransactionClassification[]
  plaidIdentityAddress     String?
  plaidIdentityEmail       String?
  plaidIdentityPhone       String?
  plaidInstitutionName     String?
  plaidAccountName         String?
  plaidAccountMask         String?
  plaidAccountSubtype      String?
  availableBalance         Decimal?
  avgWeeklyIncome          Decimal?
  depositCount90d          Int?
  largestDeposit           Decimal?
  depositCadence           String?
  // Day-of-week (0=Sunday … 6=Saturday) computed from the borrower's
  // bank deposits — typically the day after the largest recurring
  // income lands, when balance is freshest. Used by the offer accept
  // flow to snap each weekly payment due date so ACH debits land when
  // money is most likely to be there.
  preferredChargeDay       Int?
  lastPlaidRefresh         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  documents       Document[]
  payments        Payment[]
  collectionEvents CollectionEvent[]
  contact         Contact?

  @@index([status])
  @@index([email])
  @@index([ssnHash])
  @@index([plaidItemId])
}

model TransactionClassification {
  id               String   @id @default(uuid())
  applicationId    String
  counterpartyName String
  classification   String
  txCount          Int
  totalAmount      Decimal
  isInflow         Boolean  @default(true)
  sampleTxId       String
  sampleTxDate     DateTime
  sampleTxAmount   Decimal
  classifiedAt     DateTime @default(now())
  application      Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, counterpartyName])
  @@index([applicationId])
}

model Document {
  id            String   @id @default(uuid())
  applicationId String
  fileName      String
  mimeType      String
  fileSize      Int
  storagePath   String
  documentType  String   @default("PAY_STUB")
  createdAt     DateTime @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model LoanRule {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("ADMIN")
  createdAt    DateTime  @default(now())
  contacts     Contact[]
}

model Payment {
  id              String    @id @default(uuid())
  applicationId   String
  amount          Decimal
  principal       Decimal
  interest        Decimal
  lateFee         Decimal   @default(0)
  dueDate         DateTime
  paidAt          DateTime?
  status          String    @default("PENDING")
  paymentNumber   Int
  achTransferId   String?
  increaseTransferId     String?
  increaseTransferStatus String?
  increaseLastError      String?
  // Human-readable explanation of why an ACH debit returned (NSF,
  // account closed, customer revoked auth, etc.). Populated from
  // Increase's return.return_reason_code on the transfer object when
  // we detect a returned/rejected status. Shown next to the RETURNED
  // pill in the payment schedule.
  increaseReturnReason   String?
  // Every ACH initiation against this Payment, in order. We used to
  // overwrite increaseTransferId on each retry and lose the trail —
  // the audit button could only check the latest transfer's status,
  // hiding the fact that we'd tried (and seen returns on) earlier
  // attempts too. PaymentAttempt is the source of truth for that
  // history; the latest one's transferId is mirrored onto Payment.
  attempts        PaymentAttempt[]
  retryCount      Int       @default(0)
  lastRetryAt     DateTime?
  // Running total of money actually pulled from the borrower's bank
  // for this payment, across all successful ACH attempts (full +
  // partial micro-collections). When collectedAmount >= amount the
  // row flips to PAID; otherwise the row stays open with the
  // outstanding balance = amount - collectedAmount.
  collectedAmount Decimal   @default(0)
  createdAt       DateTime  @default(now())
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([status])
  @@index([dueDate])
}

// One row per ACH initiation against a Payment. Created when:
//   - payment-processor cron kicks off the scheduled debit
//   - admin clicks "Charge now" / "Recharge now"
//   - payment-retry cron re-attempts a FAILED row
//   - portal early-payoff debit
// Updated when status pollers + the webhook observe the transfer
// reaching a terminal state. Lets the admin see every attempt, not
// just the latest one, when a payment has been retried multiple
// times.
model PaymentAttempt {
  id                     String   @id @default(uuid())
  paymentId              String
  payment                Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  attemptNumber          Int
  initiatedAt            DateTime @default(now())
  initiatedBy            String   // "system:payment-processor" | "system:payment-retry" | "admin:bar@..." | "portal:Patricia Giglio" | etc.
  amount                 Decimal
  increaseTransferId     String?
  increaseTransferStatus String?  // last polled status — settled / returned / submitted / ...
  finalStatus            String?  // PAID | RETURNED | FAILED | null while in flight
  settledAt              DateTime?
  returnReason           String?  // human-readable, e.g. "Insufficient funds (R01)"

  @@index([paymentId, attemptNumber])
  @@index([increaseTransferId])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String
  performedBy String
  details     String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([createdAt])
}

model RiskProfile {
  id               String    @id @default(uuid())
  applicationId    String
  ssnHash          String
  platform         String
  monthlyIncome    Decimal
  loanAmount       Decimal
  loanTermMonths   Int
  interestRate     Decimal
  outcome          String
  totalPaid        Decimal
  totalOwed        Decimal
  latePaymentCount Int       @default(0)
  defaultedAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@index([platform])
  @@index([outcome])
  @@index([ssnHash])
}

model CollectionEvent {
  id            String   @id @default(uuid())
  applicationId String
  eventType     String
  performedBy   String?
  notes         String?
  createdAt     DateTime @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model RiskModel {
  id           String   @id @default(uuid())
  version      Int
  coefficients String
  intercept    Float
  features     String
  trainingSize Int
  accuracy     Float
  precision    Float
  recall       Float
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ─── Content Management ─────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  articles    Article[]

  @@index([slug])
}

model Tag {
  id        String       @id @default(uuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())
  articles  ArticleTag[]

  @@index([slug])
}

model ArticleTag {
  id        String  @id @default(uuid())
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

model Article {
  id              String       @id @default(uuid())
  title           String
  slug            String       @unique
  body            String
  excerpt         String?
  featuredImage   String?
  categoryId      String?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonicalUrl    String?
  noIndex         Boolean      @default(false)
  published       Boolean      @default(false)
  publishedAt     DateTime?
  // SEO-calendar fields. When the planner schedules an article, we
  // create a draft Article with scheduledFor set + minimal body (just
  // the outline). The daily cron publishes any draft with
  // scheduledFor <= now AND body filled. contentGenerated tracks
  // whether the AI has filled the body or it's still a stub.
  scheduledFor       DateTime?
  contentGenerated   Boolean   @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  category        Category?    @relation(fields: [categoryId], references: [id])
  tags            ArticleTag[]

  @@index([slug])
  @@index([published])
  @@index([categoryId])
  @@index([scheduledFor])
}

