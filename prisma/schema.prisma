  @@index([published])
}

// ─── CRM ─────────────────────────────────────────────────────

model Contact {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String?
  email           String    @unique
  phone           String?
  stage           String    @default("LEAD")
  assignedRepId   String?
  assignedRep     AdminUser? @relation(fields: [assignedRepId], references: [id])
  source          String?
  pennyClickId    String?
  smsOptIn        Boolean   @default(true)
  smsOptOutAt     DateTime?
  phoneVerifiedAt DateTime?
  utmSource       String?
  utmCampaign     String?
  utmMedium       String?
  utmTerm         String?
  utmContent      String?
  gclid           String?
  gbraid          String?
  wbraid          String?
  fbclid          String?
  ttclid          String?
  msclkid         String?
  landingPage     String?
  referrer        String?
  userAgent       String?
  ipAddress       String?
  applicationId   String?   @unique
  application     Application? @relation(fields: [applicationId], references: [id])
  lastAppStep     Int?
  loanAmountIntent Decimal?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tags                ContactTag[]
  activities          Activity[]
  emailEvents         EmailEvent[]
  sequenceEnrollments SequenceEnrollment[]
  agentSessions       AgentSession[]
  verifications       AgentVerification[]
  tickets             SupportTicket[]

  @@index([stage])
  @@index([assignedRepId])
  // Admin-archived contacts are hidden from the default contacts list
  // (and from CRM stats) but kept in the DB so we don't lose history.
  // Null = active. Set = archived at this timestamp.
  archivedAt   DateTime?

  @@index([email])
  @@index([createdAt])
  @@index([pennyClickId])
  @@index([archivedAt])
}

model ContactTag {
  id        String  @id @default(uuid())
  contactId String
  tag       String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, tag])
  @@index([contactId])
  @@index([tag])
}

model Activity {
  id          String   @id @default(uuid())
  contactId   String
  type        String
  title       String
  details     String?
  performedBy String?
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([contactId])
  @@index([type])
  @@index([createdAt])
}

model FormTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  steps       String   @default("[]")
  isDefault   Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// ─── Email Marketing ─────────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  subject   String
  body      String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailCampaign {
  id            String    @id @default(uuid())
  name          String
  subject       String
  body          String
  templateId    String?
  segmentRules  String    @default("[]")
  audienceCount Int       @default(0)
  status        String    @default("DRAFT")
  scheduledAt   DateTime?
  sentAt        DateTime?
  totalSent     Int       @default(0)
  totalOpened   Int       @default(0)
  totalClicked  Int       @default(0)
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

model EmailSequence {
  id           String   @id @default(uuid())
  name         String
  description  String?
  steps        String   @default("[]")
  triggerType  String
  triggerValue String?
  active       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SequenceEnrollment {
  id          String    @id @default(uuid())
  contactId   String
  sequenceId  String
  currentStep Int       @default(0)
  status      String    @default("ACTIVE")
  nextSendAt  DateTime?
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  enrolledAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([contactId, sequenceId])
  @@index([status])
  @@index([nextSendAt])
}

model EmailEvent {
  id         String   @id @default(uuid())
  contactId  String
  campaignId String?
  sequenceId String?
  type       String
  subject    String?
  messageId  String?
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([contactId])
  @@index([campaignId])
  @@index([type])
}

/// Notification center configuration. One singleton row. Each field is a
/// comma-separated list of emails that receive the notification for that
/// event. Empty string disables the notification entirely.
model NotificationConfig {
  id                          String   @id @default("singleton")
  // Fired when the chat widget creates a brand-new session (lead provides
  // their name + email before the first message).
  chatStartedEmails           String   @default("")
  // Fired when a public funnel applicant submits the application.
  applicationSubmittedEmails  String   @default("")
  // Fired when a brand-new Contact is created (lead capture from any
  // source: funnel, chat, landing page form, etc.)
  leadCreatedEmails           String   @default("")
  // Fired when an inbound email lands at info@pennylime.com and matches
  // a known Contact. POSTed by the email provider's inbound webhook.
  inboundEmailEmails          String   @default("")
  // Fired when an Increase ACH debit settles and a Payment row flips
  // to PAID (whether via webhook push or payment-status cron poll).
  paymentSettledEmails        String   @default("")
  // Fired when an Increase ACH debit returns (NSF/R-code) or fails,
  // i.e. money didn't get pulled. Highest-priority of the three.
  paymentFailedEmails         String   @default("")
  // Fired when the payment-processor cron kicks off a new ACH debit
  // (Payment goes PENDING -> PROCESSING). Useful for treasury but can
  // be noisy on funded-loan-heavy days.
  paymentInitiatedEmails      String   @default("")
  updatedAt                   DateTime @updatedAt
}

model TrackingConfig {
  id                            String   @id @default("singleton")
  // Google Ads
  googleAdsConversionId         String?
  googleAdsDeveloperToken       String?
  googleAdsCustomerId           String?
  googleAdsLoginCustomerId      String?
  googleAdsRefreshToken         String?
  googleAdsClientId             String?
  googleAdsClientSecret         String?
  // GA4
  ga4MeasurementId              String?
  ga4ApiSecret                  String?
  // Meta
  metaPixelId                   String?
  metaConversionsApiToken       String?
  metaTestEventCode             String?
  metaAdAccountId               String?
  // TikTok
  tiktokPixelId                 String?
  tiktokAccessToken             String?
  tiktokTestEventCode           String?
  // Microsoft Ads (Bing)
  microsoftUetTagId             String?
  microsoftConversionsApiToken  String?
  // Per-event conversion mappings (JSON: { event_name: { google_ads_label, meta_event, tiktok_event, microsoft_goal } })
  eventMappings                 String   @default("{}")
  // Raw script injection
  customHeadHtml                String?
  customBodyHtml                String?
  // Twilio SMS
  twilioAccountSid              String?
  twilioAuthToken               String?
  twilioFromNumber              String?
  twilioMessagingServiceSid     String?
  twilioVerifyServiceSid        String?
  // Toggles
  enabled                       Boolean  @default(true)
  testMode                      Boolean  @default(false)
  updatedAt                     DateTime @updatedAt
}

model TrackingEvent {
  id            String   @id @default(uuid())
  eventName     String
  contactId     String?
  applicationId String?
  pennyClickId  String?
  clickIds      String   @default("{}")
  payload       String   @default("{}")
  platforms     String   @default("{}")
  value         Decimal?
  currency      String?  @default("USD")
  status        String   @default("pending")
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([eventName])
  @@index([contactId])
  @@index([pennyClickId])
  @@index([status])
  @@index([createdAt])
}

model PennyClick {
  id               String   @id
  contactId        String?
  visitCount       Int      @default(1)
  // first-touch attribution
  firstUtmSource   String?
  firstUtmMedium   String?
  firstUtmCampaign String?
  firstUtmTerm     String?
  firstUtmContent  String?
  firstGclid       String?
  firstGbraid      String?
  firstWbraid      String?
  firstFbclid      String?
  firstTtclid      String?
  firstMsclkid     String?
  firstLandingPage String?
  firstReferrer    String?
  firstUserAgent   String?
  firstIpAddress   String?
  firstCountry     String?
  // last-touch attribution
  lastUtmSource    String?
  lastUtmMedium    String?
  lastUtmCampaign  String?
  lastGclid        String?
  lastFbclid       String?
  lastTtclid       String?
  lastMsclkid      String?
  lastLandingPage  String?
  firstSeen        DateTime @default(now())
  lastSeen         DateTime @default(now())
  pageViews        PageView[]

  @@index([contactId])
  @@index([firstSeen])
}

model PageView {
  id           String    @id @default(uuid())
  pennyClickId String
  path         String
  referrer     String?
  userAgent    String?
  ipAddress    String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  country      String?
  createdAt    DateTime  @default(now())
  pennyClick   PennyClick @relation(fields: [pennyClickId], references: [id], onDelete: Cascade)

  @@index([pennyClickId])
  @@index([createdAt])
  @@index([path])
}

model InboundEmail {
  id           String   @id @default(uuid())
  fromEmail    String
  fromName     String?
  toEmail      String?
  subject      String   @default("(no subject)")
  bodyText     String   @default("")
  bodyHtml     String?
  // Postmark/Mailgun providers retry delivery on transient errors; we
  // dedupe on messageId so the same inbound email doesn't show up twice
  // in /admin/inbox. NULLs are allowed (some providers don't include
  // messageId in the JSON payload).
  messageId    String?  @unique
  inReplyTo    String?
  // Matched contact, if any. NULL = "stranger" email; admin can view in
  // the inbox and decide to create a contact + reply.
  contactId    String?
  // Whether an admin has marked this as read / handled. We track read
  // separately from replied so junk can be archived without sending a
  // reply.
  status       String   @default("UNREAD")    // UNREAD | READ | REPLIED | ARCHIVED
  receivedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([receivedAt])
  @@index([contactId])
  @@index([fromEmail])
}

model AdvanceTopUpRequest {
  id              String   @id @default(uuid())
  applicationId   String
  contactId       String?
  requestedAmount Decimal
  // PENDING -> admin reviews; APPROVED -> ready to fund; DECLINED -> denied;
  // FUNDED -> the new advance has been wired. Status transitions are admin
  // actions, the customer only ever creates a PENDING row from /portal.
  status          String   @default("PENDING")
  adminNote       String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([applicationId])
  @@index([contactId])
  @@index([status])
  @@index([createdAt])
}

model AdSpend {
  id          String   @id @default(uuid())
  date        DateTime
  platform    String
  campaign    String?
  spend       Decimal
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  currency    String   @default("USD")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([platform])
}

model SmsTemplate {
  id          String   @id @default(uuid())
  name        String
  body        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SmsMessage {
  id              String   @id @default(uuid())
  contactId       String?
  toNumber        String
  fromNumber      String
  body            String
  templateId      String?
  campaignId      String?
  twilioSid       String?  @unique
  status          String   @default("queued") // queued, sent, delivered, failed, undelivered
  errorMessage    String?
  errorCode       String?
  segments        Int      @default(1)
  priceUsd        Decimal?
  sentAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contactId])
  @@index([status])
  @@index([twilioSid])
  @@index([createdAt])
