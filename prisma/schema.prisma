/// Immutable record of a customer's ACH authorization at offer
/// acceptance. Captures the exact text shown, the schedule they
/// agreed to, IP/user-agent, and the agreement version hash so we
/// can prove later what was on screen when they clicked.
// OFAC / PEP sanctions screening. Run on application submit (best
// effort) and again at approval (admin-blocking). Hits the
// OpenSanctions API which aggregates OFAC SDN, EU/UN/UK consolidated
// sanctions, and Politically Exposed Persons (PEP) lists, updated
// daily. Retained 5 years per BSA / 31 CFR 1010.430.
//
// status:
//   CLEAR  - no matches above threshold; safe to proceed
//   REVIEW - one or more partial matches; admin review required
//   MATCH  - high-confidence match; do not fund without remediation
model SanctionsScreening {
  id              String   @id @default(uuid())
  applicationId   String
  fullName        String
  dateOfBirth     String?
  addressCountry  String?
  provider        String   @default("opensanctions")
  status          String
  hitCount        Int      @default(0)
  rawResponse     String?
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNote      String?
  screenedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([applicationId])
  @@index([status])
  @@index([screenedAt])
}

// State-specific Commercial Financing Disclosure Law (CFDL) disclosure.
// Required by NY, CA, UT, VA, GA, CT, MO, KS (and growing). Generated +
// delivered to the merchant BEFORE they sign the Receivables Purchase
// Agreement, with its own scroll-and-sign. Retained for the state-
// mandated period (5+ years across all current CFDL states).
model CfdlDisclosure {
  id                String   @id @default(uuid())
  applicationId     String
  state             String   // NY | CA | UT | VA | GA
  // Calculation snapshot at sign time (immutable evidence of what we
  // showed the merchant). All other amounts on the Application can change
  // later via cancel + re-offer; this row reflects the specific quote the
  // merchant saw and signed off on.
  disbursedAmount   Decimal
  totalRepayment    Decimal
  financeCharge     Decimal
  aprPercent        Float    // APR-equivalent on the factor-rate transaction
  termDays          Int
  specifiedPercent  Float    // % of receivables remitted per payment
  weeklyPayment     Decimal
  // Signing evidence
  signedName        String
  signedAt          DateTime @default(now())
  signedIp          String?
  signedUserAgent   String?
  scrolledToBottom  Boolean  @default(false)
  // Template version + body hash so we can prove exactly what was shown
  // if the regulator asks. Body itself stored as a Document for retrieval.
  templateVersion   String   @default("v1-2026-05-28")
  bodyHash          String?  // SHA-256 of the rendered disclosure text
  documentId        String?  // links to Document storing the signed PDF
  createdAt         DateTime @default(now())

  @@index([applicationId])
  @@index([state])
  @@index([signedAt])
}

model AchAuthorization {
  id                  String   @id @default(uuid())
  applicationId       String
  contactId           String?
  acceptedAt          DateTime @default(now())
  ipAddress           String?
  userAgent           String?
  bankAccountMask     String?  // last 4 of debited account
  bankName            String?
  scheduleJson        String   // JSON: [{ date, amount, principal, interest }]
  totalDebitAmount    Decimal
  authorizationText   String   // exact text shown on screen
  agreementHash       String?  // SHA-256 of the agreement template version
  agreementVersion    String?  @default("v1-2026-05-17")
  // Stronger consent evidence — captured alongside the inline
  // agreement viewer and typed-name signature on the offer page.
  signedName          String?  // full legal name the borrower typed at acceptance
  scrolledToBottom    Boolean  @default(false) // confirmed they read to end

  @@index([applicationId])
  @@index([contactId])
}

model PhoneVerification {
  id          String    @id @default(uuid())
  phone       String
  codeHash    String
  attempts    Int       @default(0)
  verifiedAt  DateTime?
  expiresAt   DateTime
  ipAddress   String?
  contactId   String?
  createdAt   DateTime  @default(now())

  @@index([phone])
  @@index([createdAt])
}

// ============================================================================
// Social Bot
// ============================================================================

model SocialAccount {
  id                String          @id @default(uuid())
  platform          String          // "instagram" | "facebook" | "linkedin" | "tiktok"
  handle            String          // "@pennylime"
  accessToken       String          // encrypted at rest (AES-GCM via NEXTAUTH_SECRET)
  refreshToken      String?
  tokenExpiresAt    DateTime?
  platformAccountId String?         // IG business user id / FB page id / LI org id (TT not used)
  botCookies        String?         // encrypted instagrapi/cookie session blob
  botStatus         String          @default("healthy") // "healthy" | "challenged" | "banned"
  lastBotAction     DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  posts             SocialPost[]
  engagements       EngagementLog[]

  @@unique([platform, handle])
}

model SocialPost {
  id             String        @id @default(uuid())
  accountId      String
  account        SocialAccount @relation(fields: [accountId], references: [id])
  topic          String
  body           String        @db.Text
  imageUrl       String?
  scheduledFor   DateTime
  status         String        @default("pending") // "pending"|"published"|"failed"|"blocked"
  platformPostId String?
  publishError   String?       @db.Text
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())

  @@index([status, scheduledFor])
}

model TopicPool {
  id         String    @id @default(uuid())
  topic      String    @db.Text
  category   String    // "tax" | "cashflow" | "platform-tips" | "earnings" | "savings" | "news"
  lastUsedAt DateTime?
  useCount   Int       @default(0)
  active     Boolean   @default(true)
}

model EngagementTarget {
  id           String    @id @default(uuid())
  platform     String
  source       String    // "hashtag:#uberdriver" | "geo:los-angeles+keyword:doordash"
  targetHandle String
  targetPostId String?
  action       String    // "like" | "follow"
  status       String    @default("queued") // "queued"|"done"|"skipped"|"failed"
  createdAt    DateTime  @default(now())
  processedAt  DateTime?

  @@index([platform, status, createdAt])
}

model EngagementLog {
  id           String        @id @default(uuid())
  accountId    String
  account      SocialAccount @relation(fields: [accountId], references: [id])
  platform     String
  action       String        // "like" | "follow" | "unfollow"
  targetHandle String
  targetPostId String?
  success      Boolean
  error        String?       @db.Text
  createdAt    DateTime      @default(now())

  @@index([accountId, createdAt])
}

// Comments on our published posts. The cron polls Meta's Graph API and
// inserts new rows here. If the comment is a question, we generate a reply
// via Gemini and post it back via the API. status tracks the lifecycle.
model SocialComment {
  id                String   @id @default(uuid())
  platform          String   // "instagram" | "facebook"
  // The published SocialPost this comment is on (FK so we can join in admin)
  socialPostId      String?
  // Meta IDs so we can reply via /comment-id/replies
  platformPostId    String
  platformCommentId String   @unique
  fromUsername      String?
  fromUserId        String?
  text              String   @db.Text
  isQuestion        Boolean  @default(false)
  status            String   @default("new")
  // "new" → freshly fetched, not yet decided
  // "skipped" → not a question, or our own comment, or too old
  // "drafted" → AI generated a reply, waiting to post
  // "replied" → reply posted successfully
  // "failed" → reply attempt failed
  // "blocked" → reply failed blocklist
  replyText         String?  @db.Text
  replyCommentId    String?  // Meta's ID for the reply we posted
  replyError        String?  @db.Text
  commentedAt       DateTime
  fetchedAt         DateTime @default(now())
  repliedAt         DateTime?

  @@index([platform, status])
  @@index([platformPostId, status])
}

// ─── AI Support Agent ────────────────────────────────────────

model AgentSession {
  id             String   @id @default(uuid())
  channel        String   // "chat" | "sms" | "voice"
  contactId      String?
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  authLevel      String   @default("anon")
  // "ai" (Gemini answers automatically) or "human" (admin took over;
  // user messages don't trigger an AI turn and wait for an admin reply).
  mode           String   @default("ai")
  // Lead-capture fields collected by the chat widget before the user can
  // send a message. Duplicate of contact.firstName / contact.email by
  // design so we don't lose the lead if the contact upsert fails or the
  // visitor never makes it past the form.
  leadFirstName  String?
  leadLastName   String?
  leadEmail      String?
  // Tracks when the user's chat widget last polled for new messages. We
  // use it as a proxy for "user is online right now" — if it's > 30s
  // stale and admin sends a message, the message is also emailed.
  lastPolledAt   DateTime?
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  endReason      String?
  costCents      Int      @default(0)
  metadata       Json?
  // Admin-archived sessions hide from the default sessions list and
  // from the unread-count badge. Null = active.
  archivedAt     DateTime?
  // Admin-controlled triage state, separate from the derived "needs
  // reply / caught up" signal. "OPEN" (default, needs handling),
  // "WAITING_CLIENT" (we replied, waiting on the customer), or
  // "RESOLVED" (handled). Only changes when an admin clicks a button.
  handlingStatus String   @default("OPEN")
  messages       AgentMessage[]
  toolCalls      AgentToolCall[]
  tickets        SupportTicket[]
  @@index([contactId])
  @@index([channel, startedAt])
  @@index([mode, startedAt])
  @@index([archivedAt])
  @@index([handlingStatus])
}

model AgentMessage {
  id           String   @id @default(uuid())
  sessionId    String
  session      AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         String   // "user" | "assistant" | "system" | "tool"
  // Set to the admin's email when role="assistant" and the message was
  // typed by a human during takeover. Null when the AI generated it.
  senderEmail  String?
  // True when this message was emailed to the user because they were
  // offline at the time (lastPolledAt was stale). Prevents double-email.
  emailedAt    DateTime?
  text         String
  tokensIn     Int?
  tokensOut    Int?
  createdAt    DateTime @default(now())
  @@index([sessionId, createdAt])
}

model AgentToolCall {
  id            String   @id @default(uuid())
  sessionId     String
  session       AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name          String
  argsRedacted  Json
  resultStatus  String   // "ok" | "denied_auth" | "denied_confirm" | "error" | "rate_limited"
  resultSummary String?
  errorMessage  String?
  durationMs    Int
  createdAt     DateTime @default(now())
  @@index([sessionId, createdAt])
  @@index([name, resultStatus, createdAt])
}

model AgentVerification {
  id           String   @id @default(uuid())
  contactId    String
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel      String
  attempts     Int      @default(0)
  lockedUntil  DateTime?
  lastTriedAt  DateTime @default(now())
  @@unique([contactId, channel])
}

model SupportTicket {
  id              String   @id @default(uuid())
  sessionId       String?
  session         AgentSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  contactId       String?
  // Tickets intentionally survive contact deletion (audit trail). transcript
  // is snapshotted here so deleting the source session still leaves a record.
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  reason          String
  transcript      String
  status          String   @default("open")
  assignedTo      String?
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?
  @@index([status, createdAt])
}

model AgentError {
  id          String   @id @default(uuid())
  sessionId   String?
  toolName    String?
  message     String
  stack       String?
  createdAt   DateTime @default(now())
  @@index([createdAt])
}
